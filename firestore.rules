rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilitários ─────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function perfil() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil;
    }

    // Perfis com acesso amplo: veem e operam sobre todos os registros.
    function isGestor() {
      let p = perfil();
      return p == 'admin' || p == 'pós-venda' || p == 'financeiro' || p == 'super admin' || p == 'recepcao';
    }

    function isSuperAdmin() {
      return perfil() == 'super admin';
    }

    // Acesso ao módulo de Hospedagem (Festa dos Sócios): gestores + o perfil
    // restrito 'reserva' (que enxerga SOMENTE este módulo, nada de clientes).
    function isHospedagem() {
      return isGestor() || perfil() == 'reserva';
    }

    // Edição de meta própria: o usuário pode alterar SOMENTE os campos de meta
    // e o contador de interações no seu próprio doc — nunca perfil/ativo (evita
    // escalonamento de privilégio).
    function soMexeEmCamposDeMeta() {
      let permitidos = ['metas', 'tipoMeta', 'valorMeta', 'metaMensal', 'interacoesPorMes'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(permitidos);
    }

    // Dono de um lead: uid aparece em qualquer campo de atribuição.
    function isDono(data) {
      return data.vendedorId == request.auth.uid
          || data.linerId == request.auth.uid
          || data.criadoPorId == request.auth.uid
          || data.captadorId == request.auth.uid;
    }

    // ── Clientes / Leads ────────────────────────────────────────────────────
    // Gestores veem todos; vendedor/captador veem apenas os próprios leads.
    match /clientes/{docId} {
      allow read:   if isAuth() && (isGestor() || isDono(resource.data));
      allow create: if isAuth() && (isGestor() || isDono(request.resource.data));
      allow update: if isAuth() && (isGestor() || isDono(resource.data));
      allow delete: if false;
    }

    // ── Agendamentos (atendimento futuro, ainda não é lead) ──────────────────
    // TODOS os autenticados veem e operam todos os agendamentos (ticket #62):
    // a recepção lança e o vendedor precisa enxergar na agenda e converter em
    // atendimento, mesmo sem ser o dono. Sem delete (soft-delete/auditoria).
    match /agendamentos/{docId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    // ── Negociações ─────────────────────────────────────────────────────────
    match /negociacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Interações (subcoleção de clientes) ─────────────────────────────────
    match /clientes/{clienteId}/interacoes/{docId} {
      allow read, write: if isAuth();
    }

    // Habilita queries collection-group de interações (relatórios do dashboard).
    // Um match aninhado NÃO autoriza collectionGroup: é preciso o wildcard
    // recursivo. Aqui só liberamos LEITURA; as escritas continuam regidas pelos
    // matches específicos (clientes/* e contratos/*).
    match /{caminho=**}/interacoes/{docId} {
      allow read: if isAuth();
    }

    // ── Campanhas ───────────────────────────────────────────────────────────
    match /campanhas/{docId} {
      allow read, write: if isAuth();
    }

    // ── Usuários ────────────────────────────────────────────────────────────
    // Leitura: qualquer autenticado (necessário para verificar perfis na app).
    // Criação: o próprio usuário cria seu doc, ou gestor cria para outros.
    // Atualização: gestor pode tudo (gerência de usuários); o próprio usuário
    // pode editar SOMENTE os campos de meta/contador no seu doc.
    match /usuarios/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && (request.auth.uid == docId || isGestor());
      allow update: if isAuth() && (
                      isGestor() ||
                      (request.auth.uid == docId && soMexeEmCamposDeMeta())
                    );
      allow delete: if false;
    }

    // ── Config (contadores, configurações do sistema) ────────────────────────
    match /config/{docId} {
      allow read, write: if isAuth();
    }

    // ── Histórico de edições (subcoleção de clientes) ────────────────────────
    match /clientes/{clienteId}/historico/{docId} {
      allow read, write: if isAuth();
    }

    // ── Auditoria ────────────────────────────────────────────────────────────
    // Trilha imutável: apenas criação é permitida (pela app); leitura restrita
    // a gestores; update e delete bloqueados para garantir integridade.
    match /audit_log/{docId} {
      allow read:   if isAuth() && isGestor();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Notificações push (tokens FCM por usuário) ────────────────────────────
    match /notificacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Contratos pós-venda ───────────────────────────────────────────────────
    match /contratos/{docId} {
      allow read, write: if isAuth();
    }

    // Interações de contrato (subcoleção) — registradas no pós-venda.
    // Regras NÃO cascateiam: a subcoleção precisa do seu próprio match.
    match /contratos/{contratoId}/interacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Contatos do embaixador (Recepção → Contatos/Tentativas) ───────────────
    // Leitura/escrita: qualquer autenticado (quem acessa a Recepção).
    match /contatos_embaixador/{docId} {
      allow read, write: if isAuth();
    }

    // ── Modelos de mensagem (WhatsApp) ────────────────────────────────────────
    // Leitura/escrita: qualquer autenticado (modelos padrão + individuais).
    match /modelos_mensagem/{docId} {
      allow read, write: if isAuth();
    }

    // ── Tickets de suporte ────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read, write: if isAuth();
    }

    // ── Comentários de tickets (subcoleção) ───────────────────────────────────
    match /tickets/{ticketId}/comentarios/{docId} {
      allow read, write: if isAuth();
    }

    // ── Imóveis (inventário do empreendimento) e suas cotas ───────────────────
    // Leitura: qualquer autenticado (aba Análise da Pós-Venda).
    // Escrita: gestores — admin/super admin geram o inventário (seed) e a
    // sincronização de cotas roda no fluxo de importação da pós-venda.
    match /imoveis/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isGestor();
    }

    match /imoveis/{imovelId}/cotas/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isGestor();
    }

    // ── Produtos ──────────────────────────────────────────────────────────────
    // Leitura: qualquer autenticado (necessário para negociações e apresentações).
    // Escrita: exclusivo de super admin.
    match /produtos/{docId} {
      allow read:          if isAuth();
      allow create, update, delete: if isAuth() && isSuperAdmin();
    }

    // ── Festa dos Sócios: validação de trocas de quarto ──────────────────────
    // Decisão humana (aprovar/recusar a troca sugerida). Apenas gestores
    // (admin/super admin/pós-venda/financeiro/recepção) leem e escrevem.
    match /festa_socios_validacoes/{numeroQuarto} {
      allow read, write: if isAuth() && isHospedagem();
    }

    // Associação manual de quarto → contrato (sócio).
    match /festa_socios_associacoes/{numeroQuarto} {
      allow read, write: if isAuth() && isHospedagem();
    }

    // Lista de espera por categoria (hóspedes aguardando vaga).
    match /festa_socios_espera/{esperaId} {
      allow read, write: if isAuth() && isHospedagem();
    }

    // Confirmação de presença do hóspede na festa (sim/não), por quarto.
    match /festa_socios_presencas/{numeroQuarto} {
      allow read, write: if isAuth() && isHospedagem();
    }

    // ── Leads do site/quiosque (Villamor Tambaba) ───────────────────────────
    // Gravados por páginas públicas (sem login) → 'create' liberado COM validação.
    // Leitura/edição só para gestores autenticados; exclusão só super admin.
    match /leads_website/{docId} {
      function leadValido() {
        let d = request.resource.data;
        return d.nome is string && d.nome.size() >= 2 && d.nome.size() <= 120
            && d.whatsapp is string && d.whatsapp.size() >= 8 && d.whatsapp.size() <= 30
            && d.origem is string && d.origem.size() <= 40
            && d.status == 'novo'
            && d.createdAt == request.time          // impede timestamp forjado
            && d.keys().size() <= 20;               // bloqueia payload gigante
      }
      allow create: if leadValido();
      allow read, update: if isAuth() && isGestor();
      allow delete:       if isAuth() && isSuperAdmin();
    }
  }
}
