rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilitário ──────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Clientes / Leads ────────────────────────────────────────────────────
    match /clientes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Negociações ─────────────────────────────────────────────────────────
    match /negociacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Interações (subcoleção de clientes) ─────────────────────────────────
    match /clientes/{clienteId}/interacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Campanhas ───────────────────────────────────────────────────────────
    match /campanhas/{docId} {
      allow read, write: if isAuth();
    }

    // ── Usuários ────────────────────────────────────────────────────────────
    match /usuarios/{docId} {
      allow read, write: if isAuth();
    }

    // ── Config (contadores, configurações do sistema) ────────────────────────
    // Qualquer usuário autenticado pode ler e escrever — necessário para
    // gerar o número sequencial de atendimento da recepção.
    match /config/{docId} {
      allow read, write: if isAuth();
    }

    // ── Histórico de edições (subcoleção de clientes) ────────────────────────
    match /clientes/{clienteId}/historico/{docId} {
      allow read, write: if isAuth();
    }

    // ── Auditoria (exclusões e ações sensíveis) ──────────────────────────────
    match /audit_log/{docId} {
      allow read, write: if isAuth();
    }

    // ── Notificações push (tokens FCM por usuário) ────────────────────────────
    match /notificacoes/{docId} {
      allow read, write: if isAuth();
    }

    // ── Tickets de suporte ────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read, write: if isAuth();
    }

    // ── Comentários de tickets (subcoleção) ───────────────────────────────────
    match /tickets/{ticketId}/comentarios/{docId} {
      allow read, write: if isAuth();
    }
  }
}
